{
    "name": "agendav/agendav",
    "type": "project",
    "description": "CalDAV web client",
    "homepage": "https://github.com/agendav/agendav/",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.5",
        "doctrine/common": "^3.4",
        "doctrine/dbal": "^4.0",
        "doctrine/migrations": "^3.8",
        "doctrine/orm": "^3.0",
        "guzzlehttp/guzzle": "^7.9",
        "league/fractal": "^0.20",
        "monolog/monolog": "^3.7",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "ramsey/uuid": "^4.7",
        "sabre/dav": "^4.6",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.14",
        "slim/twig-view": "^3.4",
        "symfony/asset": "^7.4",
        "symfony/cache": "^7.4",
        "symfony/console": "^7.4",
        "symfony/http-foundation": "^7.4",
        "symfony/password-hasher": "^7.4",
        "symfony/security-core": "^7.4",
        "symfony/security-csrf": "^7.4",
        "symfony/stopwatch": "^7.4",
        "symfony/string": "^7.4",
        "symfony/translation": "^7.4",
        "symfony/twig-bridge": "^7.4",
        "symfony/var-exporter": "^7.4",
        "symfony/yaml": "^7.4",
        "twig/twig": "^3.10"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "AgenDAV\\": "src/"
        }
    },
    "scripts": {
        "lint": "node_modules/.bin/eclint check 'app/**' 'bin/**' 'config/**' 'resources/**' 'src/**' 'tests/**' '*.json' '*.md' '*.php' '*.yaml'",
        "test": "vendor/bin/phpunit --configuration tests/phpunit.xml"
    },
    "config": {
        "allow-plugins": {}
    }
}
