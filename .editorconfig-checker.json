{
  "Verbose": false,
  "Debug": false,
  "IgnoreDefaults": false,
  "SpacesAfterTabs": false,
  "NoColor": false,
  "Exclude": [
    "\\.php$",
    "\\.idea/",
    "docs/",
    "LICENSE",
